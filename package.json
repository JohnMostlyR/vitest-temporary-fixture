{
  "name": "vitest-temporary-fixture",
  "version": "1.2.0",
  "description": "Create temporary directories and fixtures on the fly for Vitest tests.",
  "keywords": [
    "vitest",
    "testing",
    "fixtures",
    "temporary",
    "temp",
    "test-helpers",
    "test-utils",
    "directory",
    "filesystem",
    "mock-filesystem",
    "test-fixtures",
    "cleanup"
  ],
  "homepage": "https://github.com/JohnMostlyR/vitest-temporary-fixture",
  "bugs": {
    "url": "https://github.com/JohnMostlyR/vitest-temporary-fixture/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JohnMostlyR/vitest-temporary-fixture.git"
  },
  "license": "MIT",
  "author": "Johan Meester",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "clean": "git clean -xdf .cache dist node_modules",
    "coverage": "vitest run --coverage",
    "deps:check": "pnpm update --interactive",
    "deps:update": "pnpm update",
    "deps:verify": "pnpm validate",
    "format": "prettier --ignore-path .prettierignore --list-different --write .",
    "lint": "eslint --fix .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "validate": "pnpm lint && pnpm format && pnpm typecheck && pnpm coverage && pnpm build"
  },
  "dependencies": {
    "mkdirp": "^3.0.1"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.2",
    "@ianvs/prettier-plugin-sort-imports": "4.7.0",
    "@types/node": "24.10.9",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "9.39.2",
    "eslint-plugin-sonarjs": "3.0.5",
    "prettier": "3.8.1",
    "rimraf": "6.1.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.54.0",
    "unbuild": "3.6.1",
    "unique-string": "3.0.0",
    "vitest": "4.0.16"
  },
  "peerDependencies": {
    "vitest": ">=3.0.0"
  }
}
